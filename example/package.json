{
  "name": "archen-example",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "test": "jest",
    "lint": "next lint",
    "codegen": "graphql-codegen --config codegen.ts",
    "export-schema": "archen schema --config archen.config.js --out etc/schema.graphql",
    "predev": "npm run codegen",
    "prebuild": "npm run codegen"
  },
  "dependencies": {
    "@graphiql/toolkit": "^0.11.3",
    "archen": "^4.0.0",
    "graphiql": "^4.1.2",
    "mysql2": "^3.14.1",
    "next": "15.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/client-preset": "^4.5.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.1.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5"
  }
}
